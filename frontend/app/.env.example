# Example environment variables for the frontend (Vite)
# Copy this file to `.env` or set these in your CI/build environment.
# IMPORTANT: Always set `VITE_API_BASE_URL` for production builds.

# Development backend (local)
VITE_API_BASE_URL=http://localhost:8000

# For production, set to your backend's public URL, for example:
VITE_API_BASE_URL=https://apkargbo-wellshift-backend-v1.hf.space
